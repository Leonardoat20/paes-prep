[
  {"id":501,"asignatura":"matematica_m2","tema":"Álgebra","eje_tematico":"Álgebra Lineal","subtema":"Determinante","dificultad":"media","tipo":"seleccion_multiple","anio":2023,"pregunta":"Dada A = [[2,1],[3,4]], ¿cuál es su determinante?","alternativas":["5","6","8","11"],"respuesta_correcta":"5","explicacion":"det(A) = 2×4 − 1×3 = 8 − 3 = 5."},
  {"id":502,"asignatura":"matematica_m2","tema":"Geometría Analítica","eje_tematico":"Geometría Analítica","subtema":"Distancia entre puntos","dificultad":"baja","tipo":"seleccion_multiple","anio":2022,"pregunta":"¿Cuál es la distancia entre A(1,2) y B(4,6)?","alternativas":["3","4","5","7"],"respuesta_correcta":"5","explicacion":"d = √((4−1)²+(6−2)²) = √(9+16) = √25 = 5."},
  {"id":503,"asignatura":"matematica_m2","tema":"Cálculo Diferencial","eje_tematico":"Cálculo","subtema":"Derivadas básicas","dificultad":"alta","tipo":"seleccion_multiple","anio":2023,"pregunta":"¿Cuál es la derivada de f(x) = 3x² + 2x − 5?","alternativas":["3x+2","6x+2","6x−5","3x²+2"],"respuesta_correcta":"6x+2","explicacion":"d/dx(3x²)=6x, d/dx(2x)=2, d/dx(−5)=0. f'(x)=6x+2."},
  {"id":504,"asignatura":"matematica_m2","tema":"Vectores y Matrices","eje_tematico":"Vectores","subtema":"Producto punto","dificultad":"media","tipo":"seleccion_multiple","anio":2022,"pregunta":"¿Cuál es el producto punto de u=(2,3) y v=(4,1)?","alternativas":["8","11","14","15"],"respuesta_correcta":"11","explicacion":"u·v = 2×4 + 3×1 = 8+3 = 11."},
  {"id":505,"asignatura":"matematica_m2","tema":"Geometría Analítica","eje_tematico":"Geometría Analítica","subtema":"Pendiente","dificultad":"media","tipo":"seleccion_multiple","anio":2021,"pregunta":"¿Cuál es la pendiente de la recta que pasa por (1,3) y (4,9)?","alternativas":["1","2","3","6"],"respuesta_correcta":"2","explicacion":"m = (9−3)/(4−1) = 6/3 = 2."},
  {"id":506,"asignatura":"matematica_m2","tema":"Álgebra","eje_tematico":"Álgebra Lineal","subtema":"Sistemas lineales","dificultad":"alta","tipo":"seleccion_multiple","anio":2023,"pregunta":"Sistema: 3x+2y=12 y x−y=1. ¿Cuál es la solución?","alternativas":["x=2, y=3","x=3, y=2","x=14/5, y=9/5","x=4, y=0"],"respuesta_correcta":"x=14/5, y=9/5","explicacion":"x=1+y. 3(1+y)+2y=12 → 5y=9 → y=9/5. x=14/5."},
  {"id":507,"asignatura":"matematica_m2","tema":"Cálculo Diferencial","eje_tematico":"Cálculo","subtema":"Límites","dificultad":"alta","tipo":"seleccion_multiple","anio":2022,"pregunta":"¿Cuál es el límite de (x²−1)/(x−1) cuando x→1?","alternativas":["0","1","2","Indefinido"],"respuesta_correcta":"2","explicacion":"Factorizando: (x+1)(x−1)/(x−1) = x+1 → lím x→1 = 2."},
  {"id":508,"asignatura":"matematica_m2","tema":"Geometría Analítica","eje_tematico":"Geometría Analítica","subtema":"Circunferencia","dificultad":"alta","tipo":"seleccion_multiple","anio":2021,"pregunta":"¿Cuál es el centro y radio de x²+y²−4x+6y−12=0?","alternativas":["Centro (2,−3), r=5","Centro (−2,3), r=5","Centro (2,−3), r=25","Centro (4,−6), r=5"],"respuesta_correcta":"Centro (2,−3), r=5","explicacion":"Completando cuadrado: (x−2)²+(y+3)²=25. Centro (2,−3), r=5."},
  {"id":509,"asignatura":"matematica_m2","tema":"Vectores y Matrices","eje_tematico":"Vectores","subtema":"Módulo","dificultad":"media","tipo":"seleccion_multiple","anio":2023,"pregunta":"¿Cuál es el módulo del vector v=(3,4)?","alternativas":["3,5","4","5","7"],"respuesta_correcta":"5","explicacion":"|v| = √(9+16) = √25 = 5."},
  {"id":510,"asignatura":"matematica_m2","tema":"Álgebra","eje_tematico":"Álgebra","subtema":"Logaritmos","dificultad":"alta","tipo":"seleccion_multiple","anio":2022,"pregunta":"¿Cuánto vale log₂(64)?","alternativas":["4","5","6","8"],"respuesta_correcta":"6","explicacion":"2⁶ = 64, entonces log₂(64) = 6."},
  {"id":511,"asignatura":"matematica_m2","tema":"Cálculo Diferencial","eje_tematico":"Cálculo","subtema":"Regla de la cadena","dificultad":"alta","tipo":"seleccion_multiple","anio":2023,"pregunta":"Si f(x)=(x²+1)³, ¿cuál es f'(x)?","alternativas":["3(x²+1)²","6x(x²+1)²","3x(x²+1)²","6x²(x²+1)"],"respuesta_correcta":"6x(x²+1)²","explicacion":"Regla de la cadena: f'(x)=3(x²+1)²·2x = 6x(x²+1)²."},
  {"id":512,"asignatura":"matematica_m2","tema":"Álgebra","eje_tematico":"Álgebra","subtema":"Propiedades logaritmos","dificultad":"media","tipo":"seleccion_multiple","anio":2022,"pregunta":"¿Cuánto es log(100) + log(10)?","alternativas":["2","3","20","110"],"respuesta_correcta":"3","explicacion":"log(100)=2, log(10)=1. Suma = 3. (Base 10 implícita.)"},
  {"id":513,"asignatura":"matematica_m2","tema":"Geometría Analítica","eje_tematico":"Geometría Analítica","subtema":"Ecuación recta","dificultad":"media","tipo":"seleccion_multiple","anio":2021,"pregunta":"La recta tiene pendiente 3 y pasa por (0,−2). ¿Cuál es su ecuación?","alternativas":["y=3x+2","y=3x−2","y=−2x+3","y=2x−3"],"respuesta_correcta":"y=3x−2","explicacion":"Usando y=mx+b: m=3, b=−2 → y=3x−2."},
  {"id":514,"asignatura":"matematica_m2","tema":"Vectores y Matrices","eje_tematico":"Álgebra Lineal","subtema":"Multiplicación de matrices","dificultad":"alta","tipo":"seleccion_multiple","anio":2023,"pregunta":"A=[[1,2],[0,1]] y B=[[3,0],[1,2]]. ¿Cuál es el elemento (1,1) de A×B?","alternativas":["3","4","5","6"],"respuesta_correcta":"5","explicacion":"Elemento (1,1) = 1×3 + 2×1 = 3+2 = 5."},
  {"id":515,"asignatura":"matematica_m2","tema":"Cálculo Diferencial","eje_tematico":"Cálculo","subtema":"Máximos y mínimos","dificultad":"alta","tipo":"seleccion_multiple","anio":2022,"pregunta":"¿En qué punto f(x)=x²−4x+3 tiene su mínimo?","alternativas":["x=0","x=1","x=2","x=4"],"respuesta_correcta":"x=2","explicacion":"f'(x)=2x−4=0 → x=2. f''(2)=2>0 confirma mínimo."},
  {"id":516,"asignatura":"matematica_m2","tema":"Álgebra","eje_tematico":"Álgebra","subtema":"Exponencial","dificultad":"media","tipo":"seleccion_multiple","anio":2021,"pregunta":"¿Cuánto es 5⁰ + 2⁻¹?","alternativas":["0,5","1","1,5","2"],"respuesta_correcta":"1,5","explicacion":"5⁰=1 y 2⁻¹=1/2. Suma = 1 + 0,5 = 1,5."},
  {"id":517,"asignatura":"matematica_m2","tema":"Geometría Analítica","eje_tematico":"Geometría Analítica","subtema":"Punto medio","dificultad":"baja","tipo":"seleccion_multiple","anio":2023,"pregunta":"¿Cuál es el punto medio entre A(2,4) y B(6,8)?","alternativas":["(3,5)","(4,6)","(5,7)","(8,12)"],"respuesta_correcta":"(4,6)","explicacion":"Punto medio = ((2+6)/2, (4+8)/2) = (4, 6)."},
  {"id":518,"asignatura":"matematica_m2","tema":"Vectores y Matrices","eje_tematico":"Vectores","subtema":"Ángulo entre vectores","dificultad":"alta","tipo":"seleccion_multiple","anio":2022,"pregunta":"Dos vectores son perpendiculares si su producto punto es:","alternativas":["1","−1","0","infinito"],"respuesta_correcta":"0","explicacion":"Vectores perpendiculares tienen producto punto igual a 0."},
  {"id":519,"asignatura":"matematica_m2","tema":"Cálculo Diferencial","eje_tematico":"Cálculo","subtema":"Continuidad","dificultad":"alta","tipo":"seleccion_multiple","anio":2021,"pregunta":"f(x)=x/|x| para x≠0. ¿Es continua en x=0?","alternativas":["Sí, f(0)=1","Sí, f(0)=0","No, tiene discontinuidad de salto","No, tiene asíntota"],"respuesta_correcta":"No, tiene discontinuidad de salto","explicacion":"Para x>0: f(x)=1; para x<0: f(x)=−1. Los límites laterales son distintos → discontinuidad de salto."},
  {"id":520,"asignatura":"matematica_m2","tema":"Álgebra","eje_tematico":"Álgebra","subtema":"Binomio de Newton","dificultad":"alta","tipo":"seleccion_multiple","anio":2023,"pregunta":"¿Cuál es el tercer término del desarrollo de (x+2)⁴?","alternativas":["8x²","24x²","16x²","6x²"],"respuesta_correcta":"24x²","explicacion":"Término k=2: C(4,2)·x²·2² = 6·x²·4 = 24x²."},
  {"id":521,"asignatura":"matematica_m2","tema":"Geometría Analítica","eje_tematico":"Geometría Analítica","subtema":"Parábola","dificultad":"alta","tipo":"seleccion_multiple","anio":2022,"pregunta":"¿Cuál es el vértice de la parábola y=x²−6x+8?","alternativas":["(3,−1)","(−3,1)","(3,1)","(6,8)"],"respuesta_correcta":"(3,−1)","explicacion":"x_v=−b/(2a)=6/2=3. y_v=9−18+8=−1. Vértice: (3,−1)."},
  {"id":522,"asignatura":"matematica_m2","tema":"Vectores y Matrices","eje_tematico":"Álgebra Lineal","subtema":"Inversa de matriz","dificultad":"alta","tipo":"seleccion_multiple","anio":2021,"pregunta":"Para que una matriz tenga inversa, su determinante debe ser:","alternativas":["0","1","Diferente de 0","Positivo"],"respuesta_correcta":"Diferente de 0","explicacion":"Una matriz es invertible si y solo si su determinante es distinto de cero (no singular)."},
  {"id":523,"asignatura":"matematica_m2","tema":"Cálculo Diferencial","eje_tematico":"Cálculo","subtema":"Derivada de producto","dificultad":"alta","tipo":"seleccion_multiple","anio":2023,"pregunta":"Si f(x)=x²·sen(x), ¿cuál es f'(x)?","alternativas":["2x·cos(x)","x²·cos(x)","2x·sen(x)+x²·cos(x)","2x·cos(x)+x²·sen(x)"],"respuesta_correcta":"2x·sen(x)+x²·cos(x)","explicacion":"Regla del producto: (uv)'=u'v+uv'. (x²)'·sen(x)+x²·(sen(x))' = 2x·sen(x)+x²·cos(x)."},
  {"id":524,"asignatura":"matematica_m2","tema":"Álgebra","eje_tematico":"Álgebra","subtema":"Progresión aritmética","dificultad":"media","tipo":"seleccion_multiple","anio":2022,"pregunta":"En la progresión aritmética 2, 5, 8, 11,... ¿cuál es el término 10?","alternativas":["27","29","29","32"],"respuesta_correcta":"29","explicacion":"aₙ = a₁ + (n−1)d = 2 + 9×3 = 2+27 = 29."},
  {"id":525,"asignatura":"matematica_m2","tema":"Geometría Analítica","eje_tematico":"Geometría Analítica","subtema":"Rectas paralelas y perpendiculares","dificultad":"media","tipo":"seleccion_multiple","anio":2021,"pregunta":"La recta r: y=2x+3. ¿Qué pendiente tiene una recta perpendicular a r?","alternativas":["2","−2","1/2","−1/2"],"respuesta_correcta":"−1/2","explicacion":"Rectas perpendiculares: m₁·m₂=−1. 2·m₂=−1 → m₂=−1/2."}
]
