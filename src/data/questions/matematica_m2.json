[
  {"id":526,"asignatura":"matematica_m2","tema":"Álgebra","eje_tematico":"Álgebra Lineal","subtema":"Determinante","dificultad":"media","tipo":"seleccion_multiple","anio":2023,"pregunta":"Dada A = [[3,1],[2,4]], ¿cuál es su determinante?","alternativas":["10","12","14","8"],"respuesta_correcta":"10","explicacion":"det(A) = 3×4 − 1×2 = 12 − 2 = 10."},
  {"id":527,"asignatura":"matematica_m2","tema":"Geometría Analítica","eje_tematico":"Geometría Analítica","subtema":"Distancia entre puntos","dificultad":"baja","tipo":"seleccion_multiple","anio":2022,"pregunta":"¿Cuál es la distancia entre A(0,0) y B(3,4)?","alternativas":["3","4","5","7"],"respuesta_correcta":"5","explicacion":"d = √(3²+4²) = √(9+16) = √25 = 5."},
  {"id":528,"asignatura":"matematica_m2","tema":"Cálculo Diferencial","eje_tematico":"Cálculo","subtema":"Derivadas básicas","dificultad":"alta","tipo":"seleccion_multiple","anio":2023,"pregunta":"¿Cuál es la derivada de f(x) = 5x³ − 2x + 7?","alternativas":["15x²−2","5x²−2","15x²+7","10x²−2"],"respuesta_correcta":"15x²−2","explicacion":"f'(x) = 15x²−2. La constante 7 desaparece."},
  {"id":529,"asignatura":"matematica_m2","tema":"Vectores y Matrices","eje_tematico":"Vectores","subtema":"Producto punto","dificultad":"media","tipo":"seleccion_multiple","anio":2022,"pregunta":"¿Cuál es el producto punto de u=(1,3) y v=(4,2)?","alternativas":["6","8","10","14"],"respuesta_correcta":"10","explicacion":"u·v = 1×4 + 3×2 = 4+6 = 10."},
  {"id":530,"asignatura":"matematica_m2","tema":"Geometría Analítica","eje_tematico":"Geometría Analítica","subtema":"Pendiente","dificultad":"media","tipo":"seleccion_multiple","anio":2021,"pregunta":"¿Cuál es la pendiente de la recta que pasa por (2,1) y (5,7)?","alternativas":["1","2","3","6"],"respuesta_correcta":"2","explicacion":"m = (7−1)/(5−2) = 6/3 = 2."},
  {"id":531,"asignatura":"matematica_m2","tema":"Álgebra","eje_tematico":"Álgebra Lineal","subtema":"Sistemas lineales","dificultad":"alta","tipo":"seleccion_multiple","anio":2023,"pregunta":"Sistema: 2x+y=7 y x+2y=5. ¿Cuál es x?","alternativas":["1","2","3","4"],"respuesta_correcta":"3","explicacion":"De la segunda: x=5−2y. Sustituyendo: 2(5−2y)+y=7 → 10−3y=7 → y=1. x=3."},
  {"id":532,"asignatura":"matematica_m2","tema":"Cálculo Diferencial","eje_tematico":"Cálculo","subtema":"Límites","dificultad":"alta","tipo":"seleccion_multiple","anio":2022,"pregunta":"¿Cuál es el límite de (x²−4)/(x−2) cuando x→2?","alternativas":["0","2","4","Indefinido"],"respuesta_correcta":"4","explicacion":"Factorizando: (x+2)(x−2)/(x−2) = x+2 → lím x→2 = 4."},
  {"id":533,"asignatura":"matematica_m2","tema":"Geometría Analítica","eje_tematico":"Geometría Analítica","subtema":"Circunferencia","dificultad":"alta","tipo":"seleccion_multiple","anio":2021,"pregunta":"¿Cuál es el radio de x²+y²−6x+2y−6=0?","alternativas":["4","5","6","16"],"respuesta_correcta":"4","explicacion":"Completando cuadrado: (x−3)²+(y+1)²=16. r = √16 = 4."},
  {"id":534,"asignatura":"matematica_m2","tema":"Vectores y Matrices","eje_tematico":"Vectores","subtema":"Módulo","dificultad":"media","tipo":"seleccion_multiple","anio":2023,"pregunta":"¿Cuál es el módulo del vector v=(5,12)?","alternativas":["7","13","17","60"],"respuesta_correcta":"13","explicacion":"|v| = √(25+144) = √169 = 13."},
  {"id":535,"asignatura":"matematica_m2","tema":"Álgebra","eje_tematico":"Álgebra","subtema":"Logaritmos","dificultad":"alta","tipo":"seleccion_multiple","anio":2022,"pregunta":"¿Cuánto vale log₃(81)?","alternativas":["3","4","5","9"],"respuesta_correcta":"4","explicacion":"3⁴ = 81, entonces log₃(81) = 4."},
  {"id":536,"asignatura":"matematica_m2","tema":"Cálculo Diferencial","eje_tematico":"Cálculo","subtema":"Regla de la cadena","dificultad":"alta","tipo":"seleccion_multiple","anio":2023,"pregunta":"Si f(x)=(3x+1)², ¿cuál es f'(x)?","alternativas":["2(3x+1)","3(3x+1)","6(3x+1)","(3x+1)"],"respuesta_correcta":"6(3x+1)","explicacion":"Regla de la cadena: f'(x)=2(3x+1)×3 = 6(3x+1)."},
  {"id":537,"asignatura":"matematica_m2","tema":"Álgebra","eje_tematico":"Álgebra","subtema":"Propiedades logaritmos","dificultad":"media","tipo":"seleccion_multiple","anio":2022,"pregunta":"¿Cuánto es log(1000) − log(10)?","alternativas":["1","2","3","100"],"respuesta_correcta":"2","explicacion":"log(1000)=3, log(10)=1. 3−1=2."},
  {"id":538,"asignatura":"matematica_m2","tema":"Geometría Analítica","eje_tematico":"Geometría Analítica","subtema":"Ecuación recta","dificultad":"media","tipo":"seleccion_multiple","anio":2021,"pregunta":"La recta tiene pendiente −2 y pasa por (0,4). ¿Cuál es su ecuación?","alternativas":["y=−2x+4","y=2x+4","y=−2x−4","y=4x−2"],"respuesta_correcta":"y=−2x+4","explicacion":"Usando y=mx+b: m=−2, b=4 → y=−2x+4."},
  {"id":539,"asignatura":"matematica_m2","tema":"Vectores y Matrices","eje_tematico":"Álgebra Lineal","subtema":"Multiplicación de matrices","dificultad":"alta","tipo":"seleccion_multiple","anio":2023,"pregunta":"A=[[2,0],[1,3]] y B=[[1,2],[0,1]]. ¿Cuál es el elemento (1,1) de A×B?","alternativas":["2","3","4","5"],"respuesta_correcta":"2","explicacion":"Elemento (1,1) = 2×1 + 0×0 = 2."},
  {"id":540,"asignatura":"matematica_m2","tema":"Cálculo Diferencial","eje_tematico":"Cálculo","subtema":"Máximos y mínimos","dificultad":"alta","tipo":"seleccion_multiple","anio":2022,"pregunta":"¿En qué punto f(x)=x²−6x+5 tiene su mínimo?","alternativas":["x=0","x=2","x=3","x=6"],"respuesta_correcta":"x=3","explicacion":"f'(x)=2x−6=0 → x=3. f''(3)=2>0 confirma mínimo."},
  {"id":541,"asignatura":"matematica_m2","tema":"Álgebra","eje_tematico":"Álgebra","subtema":"Exponencial","dificultad":"media","tipo":"seleccion_multiple","anio":2021,"pregunta":"¿Cuánto es 3⁰ + 4⁻¹?","alternativas":["0,5","1","1,25","2"],"respuesta_correcta":"1,25","explicacion":"3⁰=1 y 4⁻¹=1/4=0,25. Suma = 1,25."},
  {"id":542,"asignatura":"matematica_m2","tema":"Geometría Analítica","eje_tematico":"Geometría Analítica","subtema":"Punto medio","dificultad":"baja","tipo":"seleccion_multiple","anio":2023,"pregunta":"¿Cuál es el punto medio entre A(1,3) y B(5,7)?","alternativas":["(2,4)","(3,5)","(4,6)","(6,10)"],"respuesta_correcta":"(3,5)","explicacion":"Punto medio = ((1+5)/2, (3+7)/2) = (3,5)."},
  {"id":543,"asignatura":"matematica_m2","tema":"Vectores y Matrices","eje_tematico":"Vectores","subtema":"Perpendiculares","dificultad":"alta","tipo":"seleccion_multiple","anio":2022,"pregunta":"¿Cuál es el producto punto de dos vectores perpendiculares?","alternativas":["1","−1","0","infinito"],"respuesta_correcta":"0","explicacion":"Vectores perpendiculares tienen producto punto igual a 0."},
  {"id":544,"asignatura":"matematica_m2","tema":"Cálculo Diferencial","eje_tematico":"Cálculo","subtema":"Continuidad","dificultad":"alta","tipo":"seleccion_multiple","anio":2021,"pregunta":"¿Qué condición debe cumplir f(x) para ser continua en x=a?","alternativas":["f(a) existe","lím f(x) cuando x→a existe","lím f(x)=f(a) cuando x→a","Solo que el límite existe"],"respuesta_correcta":"lím f(x)=f(a) cuando x→a","explicacion":"Para continuidad en x=a se requiere que f(a) exista, el límite exista y ambos sean iguales."},
  {"id":545,"asignatura":"matematica_m2","tema":"Álgebra","eje_tematico":"Álgebra","subtema":"Binomio de Newton","dificultad":"alta","tipo":"seleccion_multiple","anio":2023,"pregunta":"¿Cuál es el segundo término del desarrollo de (x+3)³?","alternativas":["3x²","9x²","27x","3x³"],"respuesta_correcta":"9x²","explicacion":"Término k=1: C(3,1)·x²·3¹ = 3·x²·3 = 9x²."},
  {"id":546,"asignatura":"matematica_m2","tema":"Geometría Analítica","eje_tematico":"Geometría Analítica","subtema":"Parábola","dificultad":"alta","tipo":"seleccion_multiple","anio":2022,"pregunta":"¿Cuál es el vértice de la parábola y=x²−4x+3?","alternativas":["(2,−1)","(−2,1)","(2,1)","(4,3)"],"respuesta_correcta":"(2,−1)","explicacion":"x_v=4/2=2. y_v=4−8+3=−1. Vértice: (2,−1)."},
  {"id":547,"asignatura":"matematica_m2","tema":"Vectores y Matrices","eje_tematico":"Álgebra Lineal","subtema":"Inversa de matriz","dificultad":"alta","tipo":"seleccion_multiple","anio":2021,"pregunta":"¿Cuándo existe la inversa de una matriz cuadrada?","alternativas":["Siempre","Cuando su determinante es 0","Cuando su determinante es distinto de 0","Cuando es simétrica"],"respuesta_correcta":"Cuando su determinante es distinto de 0","explicacion":"Una matriz es invertible si y solo si su determinante es distinto de cero."},
  {"id":548,"asignatura":"matematica_m2","tema":"Cálculo Diferencial","eje_tematico":"Cálculo","subtema":"Derivada de producto","dificultad":"alta","tipo":"seleccion_multiple","anio":2023,"pregunta":"Si f(x)=x³·cos(x), ¿cuál es f'(x)?","alternativas":["3x²·cos(x)","−x³·sen(x)","3x²·cos(x)−x³·sen(x)","3x²·cos(x)+x³·sen(x)"],"respuesta_correcta":"3x²·cos(x)−x³·sen(x)","explicacion":"Regla del producto: (uv)'=u'v+uv' = 3x²·cos(x)+x³·(−sen(x))."},
  {"id":549,"asignatura":"matematica_m2","tema":"Álgebra","eje_tematico":"Álgebra","subtema":"Progresión aritmética","dificultad":"media","tipo":"seleccion_multiple","anio":2022,"pregunta":"En la progresión 3, 7, 11, 15,... ¿cuál es el término 8?","alternativas":["29","31","33","35"],"respuesta_correcta":"31","explicacion":"aₙ = 3 + (n−1)×4 = 3+7×4 = 3+28 = 31."},
  {"id":550,"asignatura":"matematica_m2","tema":"Geometría Analítica","eje_tematico":"Geometría Analítica","subtema":"Rectas perpendiculares","dificultad":"media","tipo":"seleccion_multiple","anio":2021,"pregunta":"La recta r: y=3x+1. ¿Qué pendiente tiene una recta perpendicular a r?","alternativas":["3","−3","1/3","−1/3"],"respuesta_correcta":"−1/3","explicacion":"Rectas perpendiculares: m₁·m₂=−1. 3·m₂=−1 → m₂=−1/3."}
]
