[
  {"id":201,"tema":"Números","pregunta":"¿Cuánto es 3/4 + 5/6?","opciones":["A) 19/12","B) 8/10","C) 3/5","D) 7/12"],"respuesta_correcta":"A","explicacion":"MCM de 4 y 6 es 12. 3/4=9/12 y 5/6=10/12. Suma: 19/12.","dificultad":"baja"},
  {"id":202,"tema":"Álgebra y Funciones","pregunta":"Si f(x) = 2x² - 3x + 1, ¿cuánto es f(2)?","opciones":["A) 3","B) 5","C) 7","D) 1"],"respuesta_correcta":"A","explicacion":"f(2) = 2(4) - 3(2) + 1 = 8 - 6 + 1 = 3.","dificultad":"baja"},
  {"id":203,"tema":"Geometría","pregunta":"Un triángulo rectángulo tiene catetos de 6 y 8. ¿Cuánto mide la hipotenusa?","opciones":["A) 10","B) 12","C) 14","D) 9"],"respuesta_correcta":"A","explicacion":"Pitágoras: h² = 6² + 8² = 36 + 64 = 100. h = 10.","dificultad":"baja"},
  {"id":204,"tema":"Probabilidades y Estadística","pregunta":"En un conjunto {2, 4, 6, 8, 10}, ¿cuál es la media aritmética?","opciones":["A) 6","B) 5","C) 7","D) 8"],"respuesta_correcta":"A","explicacion":"Suma = 30, cantidad = 5. Media = 30/5 = 6.","dificultad":"baja"},
  {"id":205,"tema":"Números","pregunta":"¿Cuál es el 35% de 200?","opciones":["A) 70","B) 65","C) 75","D) 80"],"respuesta_correcta":"A","explicacion":"35% de 200 = 0,35 × 200 = 70.","dificultad":"baja"},
  {"id":206,"tema":"Álgebra y Funciones","pregunta":"Resuelve: 2x - 5 = 11","opciones":["A) x = 8","B) x = 6","C) x = 3","D) x = 10"],"respuesta_correcta":"A","explicacion":"2x = 16, x = 8.","dificultad":"baja"},
  {"id":207,"tema":"Geometría","pregunta":"¿Cuánto mide el área de un rectángulo de base 7 y altura 4?","opciones":["A) 28","B) 22","C) 14","D) 11"],"respuesta_correcta":"A","explicacion":"Área = base × altura = 7 × 4 = 28.","dificultad":"baja"},
  {"id":208,"tema":"Números","pregunta":"¿Cuál es el MCM de 12 y 18?","opciones":["A) 36","B) 6","C) 24","D) 72"],"respuesta_correcta":"A","explicacion":"12 = 2²×3 y 18 = 2×3². MCM = 2²×3² = 36.","dificultad":"media"},
  {"id":209,"tema":"Álgebra y Funciones","pregunta":"¿Cuáles son las raíces de x² - 5x + 6 = 0?","opciones":["A) x=2 y x=3","B) x=1 y x=6","C) x=-2 y x=-3","D) x=5 y x=1"],"respuesta_correcta":"A","explicacion":"(x-2)(x-3)=0, luego x=2 o x=3.","dificultad":"media"},
  {"id":210,"tema":"Geometría","pregunta":"El perímetro de un cuadrado es 28 cm. ¿Cuánto mide su área?","opciones":["A) 49 cm²","B) 56 cm²","C) 64 cm²","D) 36 cm²"],"respuesta_correcta":"A","explicacion":"Lado = 28/4 = 7. Área = 7² = 49 cm².","dificultad":"media"},
  {"id":211,"tema":"Probabilidades y Estadística","pregunta":"Se lanza un dado. ¿Cuál es la probabilidad de obtener un número par?","opciones":["A) 1/2","B) 1/3","C) 2/3","D) 1/6"],"respuesta_correcta":"A","explicacion":"Números pares: {2,4,6}. P = 3/6 = 1/2.","dificultad":"baja"},
  {"id":212,"tema":"Números","pregunta":"Si a = -3 y b = 4, ¿cuánto es a² - b?","opciones":["A) 5","B) -5","C) 13","D) -13"],"respuesta_correcta":"A","explicacion":"a² = 9. 9 - 4 = 5.","dificultad":"media"},
  {"id":213,"tema":"Álgebra y Funciones","pregunta":"¿Cuál es el dominio de f(x) = √(x - 3)?","opciones":["A) x ≥ 3","B) x > 3","C) x ≤ 3","D) x ∈ ℝ"],"respuesta_correcta":"A","explicacion":"x - 3 ≥ 0 → x ≥ 3.","dificultad":"media"},
  {"id":214,"tema":"Geometría","pregunta":"Un círculo tiene radio 5. ¿Cuánto mide su área? (π ≈ 3,14)","opciones":["A) 78,5","B) 31,4","C) 15,7","D) 62,8"],"respuesta_correcta":"A","explicacion":"Área = πr² = 3,14 × 25 = 78,5.","dificultad":"baja"},
  {"id":215,"tema":"Probabilidades y Estadística","pregunta":"En una clase de 30 alumnos, 18 son mujeres. ¿Qué porcentaje son hombres?","opciones":["A) 40%","B) 60%","C) 30%","D) 70%"],"respuesta_correcta":"A","explicacion":"Hombres = 12. Porcentaje = 12/30 × 100 = 40%.","dificultad":"baja"},
  {"id":216,"tema":"Números","pregunta":"¿Cuánto es (2³ × 3²) ÷ 6?","opciones":["A) 12","B) 18","C) 6","D) 9"],"respuesta_correcta":"A","explicacion":"8 × 9 = 72. 72 ÷ 6 = 12.","dificultad":"media"},
  {"id":217,"tema":"Álgebra y Funciones","pregunta":"Si 3x + 2y = 12 y x = 2, ¿cuánto es y?","opciones":["A) 3","B) 4","C) 6","D) 2"],"respuesta_correcta":"A","explicacion":"6 + 2y = 12 → y = 3.","dificultad":"baja"},
  {"id":218,"tema":"Geometría","pregunta":"¿Cuánto mide el volumen de un cubo de arista 4?","opciones":["A) 64","B) 48","C) 96","D) 16"],"respuesta_correcta":"A","explicacion":"V = 4³ = 64.","dificultad":"baja"},
  {"id":219,"tema":"Probabilidades y Estadística","pregunta":"Los datos {3, 5, 5, 7, 9} tienen moda:","opciones":["A) 5","B) 7","C) 3","D) 9"],"respuesta_correcta":"A","explicacion":"5 aparece 2 veces, es el más frecuente.","dificultad":"baja"},
  {"id":220,"tema":"Números","pregunta":"¿Cuál es el resultado de (-2)⁴?","opciones":["A) 16","B) -16","C) 8","D) -8"],"respuesta_correcta":"A","explicacion":"Potencia par de número negativo es positivo: 16.","dificultad":"media"},
  {"id":221,"tema":"Álgebra y Funciones","pregunta":"La función f(x) = 3x - 2 es cero cuando:","opciones":["A) x = 2/3","B) x = 3/2","C) x = -2/3","D) x = 2"],"respuesta_correcta":"A","explicacion":"3x = 2 → x = 2/3.","dificultad":"media"},
  {"id":222,"tema":"Geometría","pregunta":"Dos ángulos suplementarios suman 180°. Si uno mide 65°, ¿cuánto mide el otro?","opciones":["A) 115°","B) 90°","C) 125°","D) 95°"],"respuesta_correcta":"A","explicacion":"180° - 65° = 115°.","dificultad":"baja"},
  {"id":223,"tema":"Probabilidades y Estadística","pregunta":"La mediana de {1, 3, 5, 7, 9} es:","opciones":["A) 5","B) 3","C) 7","D) 4"],"respuesta_correcta":"A","explicacion":"Con 5 datos el valor central es el 3°: 5.","dificultad":"baja"},
  {"id":224,"tema":"Números","pregunta":"¿Cuánto es 0,25 × 0,4?","opciones":["A) 0,1","B) 0,01","C) 1","D) 0,65"],"respuesta_correcta":"A","explicacion":"0,25 × 0,4 = 0,1.","dificultad":"media"},
  {"id":225,"tema":"Álgebra y Funciones","pregunta":"¿Cuál es la pendiente de la recta 2y = 6x - 4?","opciones":["A) 3","B) -2","C) 6","D) 1/3"],"respuesta_correcta":"A","explicacion":"y = 3x - 2. Pendiente m = 3.","dificultad":"media"},
  {"id":226,"tema":"Geometría","pregunta":"¿Cuántos lados tiene un hexágono regular?","opciones":["A) 6","B) 5","C) 7","D) 8"],"respuesta_correcta":"A","explicacion":"Hexa = seis.","dificultad":"baja"},
  {"id":227,"tema":"Probabilidades y Estadística","pregunta":"Se lanza una moneda 3 veces. ¿Cuántos resultados posibles hay?","opciones":["A) 8","B) 6","C) 3","D) 9"],"respuesta_correcta":"A","explicacion":"2³ = 8 resultados posibles.","dificultad":"media"},
  {"id":228,"tema":"Números","pregunta":"¿Cuál es la forma decimal de 7/8?","opciones":["A) 0,875","B) 0,75","C) 0,8","D) 0,9"],"respuesta_correcta":"A","explicacion":"7 ÷ 8 = 0,875.","dificultad":"media"},
  {"id":229,"tema":"Álgebra y Funciones","pregunta":"Si f(x) = x² + 1 y g(x) = 2x, ¿cuánto es (f∘g)(1)?","opciones":["A) 5","B) 3","C) 7","D) 4"],"respuesta_correcta":"A","explicacion":"g(1)=2, f(2)=4+1=5.","dificultad":"alta"},
  {"id":230,"tema":"Geometría","pregunta":"El ángulo interior de un triángulo equilátero mide:","opciones":["A) 60°","B) 45°","C) 90°","D) 120°"],"respuesta_correcta":"A","explicacion":"180°/3 = 60°.","dificultad":"baja"},
  {"id":231,"tema":"Probabilidades y Estadística","pregunta":"En una urna hay 3 rojas, 2 azules y 5 verdes. P(sacar roja) =","opciones":["A) 3/10","B) 1/3","C) 2/5","D) 1/5"],"respuesta_correcta":"A","explicacion":"P = 3/10.","dificultad":"baja"},
  {"id":232,"tema":"Números","pregunta":"¿Cuál es el resultado de |−7| + |3|?","opciones":["A) 10","B) 4","C) −4","D) −10"],"respuesta_correcta":"A","explicacion":"7 + 3 = 10.","dificultad":"baja"},
  {"id":233,"tema":"Álgebra y Funciones","pregunta":"¿Cuál es el vértice de la parábola f(x) = (x−2)² + 3?","opciones":["A) (2, 3)","B) (−2, 3)","C) (2, −3)","D) (3, 2)"],"respuesta_correcta":"A","explicacion":"Forma f(x)=(x−h)²+k tiene vértice (h,k)=(2,3).","dificultad":"alta"},
  {"id":234,"tema":"Geometría","pregunta":"¿Cuál es la suma de los ángulos interiores de un cuadrilátero?","opciones":["A) 360°","B) 180°","C) 270°","D) 540°"],"respuesta_correcta":"A","explicacion":"(4−2)×180° = 360°.","dificultad":"media"},
  {"id":235,"tema":"Probabilidades y Estadística","pregunta":"El rango de {4, 7, 2, 9, 5} es:","opciones":["A) 7","B) 5","C) 4","D) 9"],"respuesta_correcta":"A","explicacion":"9 − 2 = 7.","dificultad":"baja"},
  {"id":236,"tema":"Números","pregunta":"¿Cuánto es 5! (factorial de 5)?","opciones":["A) 120","B) 60","C) 24","D) 720"],"respuesta_correcta":"A","explicacion":"5! = 5×4×3×2×1 = 120.","dificultad":"media"},
  {"id":237,"tema":"Álgebra y Funciones","pregunta":"Si log₂(x) = 3, ¿cuánto vale x?","opciones":["A) 8","B) 6","C) 9","D) 4"],"respuesta_correcta":"A","explicacion":"2³ = 8.","dificultad":"alta"},
  {"id":238,"tema":"Geometría","pregunta":"Los ángulos alternos internos formados por dos paralelas y una transversal son:","opciones":["A) Iguales","B) Suplementarios","C) Complementarios","D) Adyacentes"],"respuesta_correcta":"A","explicacion":"Son iguales cuando las rectas son paralelas.","dificultad":"media"},
  {"id":239,"tema":"Probabilidades y Estadística","pregunta":"¿Cuál es la varianza de {2, 2, 2, 2}?","opciones":["A) 0","B) 2","C) 4","D) 1"],"respuesta_correcta":"A","explicacion":"Sin dispersión, varianza = 0.","dificultad":"media"},
  {"id":240,"tema":"Números","pregunta":"¿Cuánto es √144 + √25?","opciones":["A) 17","B) 13","C) 19","D) 15"],"respuesta_correcta":"A","explicacion":"12 + 5 = 17.","dificultad":"baja"},
  {"id":241,"tema":"Álgebra y Funciones","pregunta":"¿Cuántas soluciones reales tiene x² + 4 = 0?","opciones":["A) Ninguna","B) Una","C) Dos","D) Infinitas"],"respuesta_correcta":"A","explicacion":"x² = −4 no tiene solución real.","dificultad":"media"},
  {"id":242,"tema":"Geometría","pregunta":"¿Cuánto mide el área de un trapecio con bases 6 y 10 y altura 4?","opciones":["A) 32","B) 24","C) 40","D) 16"],"respuesta_correcta":"A","explicacion":"(6+10)/2 × 4 = 32.","dificultad":"media"},
  {"id":243,"tema":"Probabilidades y Estadística","pregunta":"De 100 personas, 40 prefieren fútbol. ¿Qué fracción prefiere fútbol?","opciones":["A) 2/5","B) 3/10","C) 1/4","D) 1/2"],"respuesta_correcta":"A","explicacion":"40/100 = 2/5.","dificultad":"baja"},
  {"id":244,"tema":"Números","pregunta":"¿Cuál de los siguientes es un número irracional?","opciones":["A) √2","B) 1/3","C) 0,5","D) −4"],"respuesta_correcta":"A","explicacion":"√2 no es periódico ni termina.","dificultad":"media"},
  {"id":245,"tema":"Álgebra y Funciones","pregunta":"Si x+y=5 y x−y=1, ¿cuánto vale x?","opciones":["A) 3","B) 2","C) 4","D) 1"],"respuesta_correcta":"A","explicacion":"Sumando: 2x=6 → x=3.","dificultad":"media"},
  {"id":246,"tema":"Geometría","pregunta":"¿Cuánto mide el perímetro de un triángulo equilátero de lado 7?","opciones":["A) 21","B) 14","C) 28","D) 49"],"respuesta_correcta":"A","explicacion":"3 × 7 = 21.","dificultad":"baja"},
  {"id":247,"tema":"Probabilidades y Estadística","pregunta":"Si P(A)=0,3 y P(B)=0,5 son independientes, ¿cuánto es P(A∩B)?","opciones":["A) 0,15","B) 0,8","C) 0,2","D) 0,35"],"respuesta_correcta":"A","explicacion":"P(A∩B) = 0,3 × 0,5 = 0,15.","dificultad":"alta"},
  {"id":248,"tema":"Números","pregunta":"¿Cuál es el resultado de 2⁻³?","opciones":["A) 1/8","B) −8","C) −6","D) 6"],"respuesta_correcta":"A","explicacion":"2⁻³ = 1/8.","dificultad":"media"},
  {"id":249,"tema":"Álgebra y Funciones","pregunta":"La función f(x) = |x| tiene imagen (recorrido):","opciones":["A) [0, +∞)","B) ℝ","C) (−∞, 0]","D) (0, +∞)"],"respuesta_correcta":"A","explicacion":"El valor absoluto es siempre ≥ 0.","dificultad":"alta"},
