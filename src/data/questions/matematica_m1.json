[
  {"id":101,"asignatura":"matematica_m1","tema":"Números","eje_tematico":"Números y Operaciones","subtema":"Potencias","dificultad":"baja","tipo":"seleccion_multiple","anio":2023,"pregunta":"¿Cuánto es 2³ × 2²?","alternativas":["2⁵","2⁶","4⁵","2¹"],"respuesta_correcta":"2⁵","explicacion":"Al multiplicar potencias de igual base se suman exponentes: 2³ × 2² = 2^(3+2) = 2⁵ = 32."},
  {"id":102,"asignatura":"matematica_m1","tema":"Álgebra y Funciones","eje_tematico":"Álgebra","subtema":"Ecuaciones primer grado","dificultad":"baja","tipo":"seleccion_multiple","anio":2023,"pregunta":"Si 3x + 6 = 18, ¿cuánto vale x?","alternativas":["2","3","4","6"],"respuesta_correcta":"4","explicacion":"3x = 12 → x = 4."},
  {"id":103,"asignatura":"matematica_m1","tema":"Probabilidades y Estadística","eje_tematico":"Probabilidad","subtema":"Probabilidad simple","dificultad":"baja","tipo":"seleccion_multiple","anio":2022,"pregunta":"Al lanzar un dado de seis caras, ¿cuál es la probabilidad de obtener un número par?","alternativas":["1/6","1/3","1/2","2/3"],"respuesta_correcta":"1/2","explicacion":"Pares: {2,4,6} = 3 casos de 6 → P = 1/2."},
  {"id":104,"asignatura":"matematica_m1","tema":"Geometría","eje_tematico":"Geometría Plana","subtema":"Área rectángulo","dificultad":"baja","tipo":"seleccion_multiple","anio":2022,"pregunta":"¿Cuál es el área de un rectángulo de base 8 cm y altura 5 cm?","alternativas":["13 cm²","26 cm²","40 cm²","80 cm²"],"respuesta_correcta":"40 cm²","explicacion":"Área = base × altura = 8 × 5 = 40 cm²."},
  {"id":105,"asignatura":"matematica_m1","tema":"Álgebra y Funciones","eje_tematico":"Funciones","subtema":"Función lineal","dificultad":"media","tipo":"seleccion_multiple","anio":2023,"pregunta":"La función f(x) = 2x − 3 pasa por el punto (a, 5). ¿Cuánto vale a?","alternativas":["1","2","3","4"],"respuesta_correcta":"4","explicacion":"2a − 3 = 5 → 2a = 8 → a = 4."},
  {"id":106,"asignatura":"matematica_m1","tema":"Probabilidades y Estadística","eje_tematico":"Estadística","subtema":"Moda","dificultad":"media","tipo":"seleccion_multiple","anio":2021,"pregunta":"Los puntajes de 5 estudiantes son: 60, 75, 80, 80, 90. ¿Cuál es la moda?","alternativas":["75","77","80","90"],"respuesta_correcta":"80","explicacion":"La moda es el valor que más se repite: 80 aparece dos veces."},
  {"id":107,"asignatura":"matematica_m1","tema":"Números","eje_tematico":"Números y Operaciones","subtema":"Fracciones","dificultad":"media","tipo":"seleccion_multiple","anio":2022,"pregunta":"¿Cuánto es 3/4 + 2/3?","alternativas":["5/7","5/12","17/12","11/12"],"respuesta_correcta":"17/12","explicacion":"MCM(4,3)=12. 9/12 + 8/12 = 17/12."},
  {"id":108,"asignatura":"matematica_m1","tema":"Álgebra y Funciones","eje_tematico":"Álgebra","subtema":"Sistemas de ecuaciones","dificultad":"alta","tipo":"seleccion_multiple","anio":2023,"pregunta":"¿Cuál es la solución del sistema x + y = 7 y 2x − y = 5?","alternativas":["x=3, y=4","x=4, y=3","x=2, y=5","x=5, y=2"],"respuesta_correcta":"x=4, y=3","explicacion":"Sumando: 3x = 12 → x = 4. Reemplazando: y = 3."},
  {"id":109,"asignatura":"matematica_m1","tema":"Geometría","eje_tematico":"Geometría Plana","subtema":"Pitágoras","dificultad":"alta","tipo":"seleccion_multiple","anio":2022,"pregunta":"En un triángulo rectángulo, los catetos miden 6 y 8 cm. ¿Cuánto mide la hipotenusa?","alternativas":["7 cm","10 cm","12 cm","14 cm"],"respuesta_correcta":"10 cm","explicacion":"c² = 6² + 8² = 36 + 64 = 100 → c = 10 cm."},
  {"id":110,"asignatura":"matematica_m1","tema":"Probabilidades y Estadística","eje_tematico":"Probabilidad","subtema":"Probabilidad compuesta","dificultad":"alta","tipo":"seleccion_multiple","anio":2021,"pregunta":"Se lanzan dos monedas. ¿Cuál es la probabilidad de obtener exactamente una cara?","alternativas":["1/4","1/2","3/4","1"],"respuesta_correcta":"1/2","explicacion":"Espacio muestral: {CC, CS, SC, SS}. Casos favorables: {CS, SC} = 2/4 = 1/2."},
  {"id":111,"asignatura":"matematica_m1","tema":"Números","eje_tematico":"Números y Operaciones","subtema":"Porcentajes","dificultad":"media","tipo":"seleccion_multiple","anio":2023,"pregunta":"¿Cuánto es el 30% de 250?","alternativas":["55","65","75","85"],"respuesta_correcta":"75","explicacion":"0,3 × 250 = 75."},
  {"id":112,"asignatura":"matematica_m1","tema":"Álgebra y Funciones","eje_tematico":"Funciones","subtema":"Función cuadrática","dificultad":"alta","tipo":"seleccion_multiple","anio":2022,"pregunta":"¿Cuáles son las raíces de x² − 5x + 6 = 0?","alternativas":["x=1 y x=6","x=2 y x=3","x=−2 y x=−3","x=−1 y x=−6"],"respuesta_correcta":"x=2 y x=3","explicacion":"(x−2)(x−3)=0 → x=2 ó x=3."},
  {"id":113,"asignatura":"matematica_m1","tema":"Geometría","eje_tematico":"Geometría Plana","subtema":"Área círculo","dificultad":"media","tipo":"seleccion_multiple","anio":2021,"pregunta":"¿Cuál es el área de un círculo de radio 5 cm? (π ≈ 3,14)","alternativas":["31,4 cm²","78,5 cm²","15,7 cm²","157 cm²"],"respuesta_correcta":"78,5 cm²","explicacion":"A = π·r² = 3,14 × 25 = 78,5 cm²."},
  {"id":114,"asignatura":"matematica_m1","tema":"Probabilidades y Estadística","eje_tematico":"Estadística","subtema":"Promedio","dificultad":"baja","tipo":"seleccion_multiple","anio":2023,"pregunta":"Las notas de un estudiante son: 4,5; 6,0; 5,5; 7,0 y 5,0. ¿Cuál es su promedio?","alternativas":["5,2","5,6","5,8","6,0"],"respuesta_correcta":"5,6","explicacion":"Suma = 28,0. Promedio = 28/5 = 5,6."},
  {"id":115,"asignatura":"matematica_m1","tema":"Números","eje_tematico":"Números y Operaciones","subtema":"Proporciones","dificultad":"media","tipo":"seleccion_multiple","anio":2022,"pregunta":"Si 3 manzanas cuestan $450, ¿cuánto cuestan 7 manzanas?","alternativas":["$900","$1.050","$1.200","$1.350"],"respuesta_correcta":"$1.050","explicacion":"Precio unitario = 150. 7 × 150 = $1.050."},
  {"id":116,"asignatura":"matematica_m1","tema":"Números","eje_tematico":"Números y Operaciones","subtema":"Números enteros","dificultad":"baja","tipo":"seleccion_multiple","anio":2022,"pregunta":"¿Cuál es el resultado de (−3) × (−4)?","alternativas":["−12","12","−7","7"],"respuesta_correcta":"12","explicacion":"Negativo por negativo = positivo. (−3)(−4) = 12."},
  {"id":117,"asignatura":"matematica_m1","tema":"Números","eje_tematico":"Números y Operaciones","subtema":"Raíz cuadrada","dificultad":"baja","tipo":"seleccion_multiple","anio":2021,"pregunta":"¿Cuánto es √144?","alternativas":["11","12","13","14"],"respuesta_correcta":"12","explicacion":"12² = 144, por lo tanto √144 = 12."},
  {"id":118,"asignatura":"matematica_m1","tema":"Álgebra y Funciones","eje_tematico":"Álgebra","subtema":"Factorización","dificultad":"media","tipo":"seleccion_multiple","anio":2022,"pregunta":"¿Cuál es la factorización de x² − 9?","alternativas":["(x−3)²","(x+3)(x−3)","(x−9)(x+1)","(x+9)(x−1)"],"respuesta_correcta":"(x+3)(x−3)","explicacion":"x²−9 es diferencia de cuadrados: (x+3)(x−3)."},
  {"id":119,"asignatura":"matematica_m1","tema":"Geometría","eje_tematico":"Geometría Plana","subtema":"Perímetro","dificultad":"baja","tipo":"seleccion_multiple","anio":2023,"pregunta":"¿Cuál es el perímetro de un cuadrado de lado 7 cm?","alternativas":["14 cm","21 cm","28 cm","49 cm"],"respuesta_correcta":"28 cm","explicacion":"Perímetro cuadrado = 4 × lado = 4 × 7 = 28 cm."},
  {"id":120,"asignatura":"matematica_m1","tema":"Probabilidades y Estadística","eje_tematico":"Estadística","subtema":"Mediana","dificultad":"media","tipo":"seleccion_multiple","anio":2021,"pregunta":"El conjunto de datos {3, 7, 2, 9, 5} ordenado es {2, 3, 5, 7, 9}. ¿Cuál es la mediana?","alternativas":["3","5","7","9"],"respuesta_correcta":"5","explicacion":"La mediana es el valor central: 2, 3, **5**, 7, 9. La mediana es 5."},
  {"id":121,"asignatura":"matematica_m1","tema":"Números","eje_tematico":"Números y Operaciones","subtema":"Orden de operaciones","dificultad":"media","tipo":"seleccion_multiple","anio":2023,"pregunta":"¿Cuánto es 3 + 4 × 2 − 1?","alternativas":["13","14","10","15"],"respuesta_correcta":"10","explicacion":"Se resuelve primero la multiplicación: 4×2=8. Luego: 3+8−1 = 10."},
  {"id":122,"asignatura":"matematica_m1","tema":"Álgebra y Funciones","eje_tematico":"Álgebra","subtema":"Inecuaciones","dificultad":"media","tipo":"seleccion_multiple","anio":2022,"pregunta":"¿Cuál es el conjunto solución de 2x − 4 > 6?","alternativas":["x > 1","x > 5","x < 5","x < 1"],"respuesta_correcta":"x > 5","explicacion":"2x > 10 → x > 5."},
  {"id":123,"asignatura":"matematica_m1","tema":"Geometría","eje_tematico":"Geometría Plana","subtema":"Ángulos","dificultad":"baja","tipo":"seleccion_multiple","anio":2021,"pregunta":"¿Cuánto mide cada ángulo interior de un triángulo equilátero?","alternativas":["45°","60°","90°","120°"],"respuesta_correcta":"60°","explicacion":"La suma de ángulos de un triángulo es 180°. En un equilátero los tres son iguales: 180/3 = 60°."},
  {"id":124,"asignatura":"matematica_m1","tema":"Números","eje_tematico":"Números y Operaciones","subtema":"MCM y MCD","dificultad":"media","tipo":"seleccion_multiple","anio":2022,"pregunta":"¿Cuál es el mínimo común múltiplo (MCM) de 4 y 6?","alternativas":["2","8","12","24"],"respuesta_correcta":"12","explicacion":"Múltiplos de 4: 4,8,12… Múltiplos de 6: 6,12… El primer común es 12."},
  {"id":125,"asignatura":"matematica_m1","tema":"Probabilidades y Estadística","eje_tematico":"Probabilidad","subtema":"Espacio muestral","dificultad":"media","tipo":"seleccion_multiple","anio":2023,"pregunta":"Una urna tiene 4 bolas rojas y 6 azules. ¿Cuál es la probabilidad de sacar una bola roja?","alternativas":["1/4","2/5","3/5","4/6"],"respuesta_correcta":"2/5","explicacion":"P(roja) = 4/10 = 2/5."},
  {"id":126,"asignatura":"matematica_m1","tema":"Álgebra y Funciones","eje_tematico":"Funciones","subtema":"Dominio y recorrido","dificultad":"alta","tipo":"seleccion_multiple","anio":2022,"pregunta":"¿Cuál es el dominio de f(x) = √(x − 3)?","alternativas":["x > 3","x ≥ 0","x ≥ 3","x ∈ ℝ"],"respuesta_correcta":"x ≥ 3","explicacion":"Para que la raíz exista, el argumento debe ser ≥ 0: x − 3 ≥ 0 → x ≥ 3."},
  {"id":127,"asignatura":"matematica_m1","tema":"Geometría","eje_tematico":"Geometría Sólida","subtema":"Volumen","dificultad":"media","tipo":"seleccion_multiple","anio":2021,"pregunta":"¿Cuál es el volumen de un cubo de arista 4 cm?","alternativas":["16 cm³","32 cm³","48 cm³","64 cm³"],"respuesta_correcta":"64 cm³","explicacion":"V = arista³ = 4³ = 64 cm³."},
  {"id":128,"asignatura":"matematica_m1","tema":"Números","eje_tematico":"Números y Operaciones","subtema":"Números racionales","dificultad":"baja","tipo":"seleccion_multiple","anio":2023,"pregunta":"¿Cuál de los siguientes números NO es racional?","alternativas":["0,333...","√4","√2","5/3"],"respuesta_correcta":"√2","explicacion":"√2 es irracional porque no puede expresarse como fracción de enteros."},
  {"id":129,"asignatura":"matematica_m1","tema":"Probabilidades y Estadística","eje_tematico":"Estadística","subtema":"Gráficos estadísticos","dificultad":"media","tipo":"seleccion_multiple","anio":2022,"pregunta":"En un gráfico de barras, el eje horizontal representa las categorías y el eje vertical representa las frecuencias. Si la barra de 'Matemática' llega a 30 y 'Lenguaje' a 20, ¿cuántos estudiantes prefieren Matemática respecto al total de ambas?","alternativas":["40%","50%","60%","75%"],"respuesta_correcta":"60%","explicacion":"Total = 30+20 = 50. Proporción Matemática = 30/50 = 60%."},
  {"id":130,"asignatura":"matematica_m1","tema":"Álgebra y Funciones","eje_tematico":"Álgebra","subtema":"Polinomios","dificultad":"alta","tipo":"seleccion_multiple","anio":2023,"pregunta":"¿Cuál es el grado del polinomio 3x⁴ − 2x² + 7x − 1?","alternativas":["2","3","4","7"],"respuesta_correcta":"4","explicacion":"El grado es el mayor exponente: 3x⁴ tiene exponente 4."},
  {"id":131,"asignatura":"matematica_m1","tema":"Geometría","eje_tematico":"Geometría Plana","subtema":"Semejanza","dificultad":"alta","tipo":"seleccion_multiple","anio":2022,"pregunta":"Dos triángulos semejantes tienen lados de 3, 4 y 5 cm el primero. Si la razón de semejanza es 2, ¿cuál es el perímetro del segundo triángulo?","alternativas":["12 cm","18 cm","24 cm","36 cm"],"respuesta_correcta":"24 cm","explicacion":"Perímetro 1° = 12 cm. Con razón 2: perímetro 2° = 12 × 2 = 24 cm."},
  {"id":132,"asignatura":"matematica_m1","tema":"Números","eje_tematico":"Números y Operaciones","subtema":"Notación científica","dificultad":"media","tipo":"seleccion_multiple","anio":2021,"pregunta":"¿Cuál es la notación científica de 0,00045?","alternativas":["4,5 × 10²","4,5 × 10⁻⁴","4,5 × 10⁻³","45 × 10⁻⁵"],"respuesta_correcta":"4,5 × 10⁻⁴","explicacion":"Movemos el punto 4 lugares a la derecha: 0,00045 = 4,5 × 10⁻⁴."},
  {"id":133,"asignatura":"matematica_m1","tema":"Álgebra y Funciones","eje_tematico":"Álgebra","subtema":"Valor numérico","dificultad":"baja","tipo":"seleccion_multiple","anio":2023,"pregunta":"Si P(x) = x² − 3x + 2, ¿cuánto es P(2)?","alternativas":["0","2","4","6"],"respuesta_correcta":"0","explicacion":"P(2) = 4 − 6 + 2 = 0."},
  {"id":134,"asignatura":"matematica_m1","tema":"Probabilidades y Estadística","eje_tematico":"Estadística","subtema":"Rango","dificultad":"baja","tipo":"seleccion_multiple","anio":2022,"pregunta":"Los datos de un conjunto son {12, 5, 20, 8, 15}. ¿Cuál es el rango?","alternativas":["8","12","15","15"],"respuesta_correcta":"15","explicacion":"Rango = valor máximo − valor mínimo = 20 − 5 = 15."},
  {"id":135,"asignatura":"matematica_m1","tema":"Geometría","eje_tematico":"Geometría Plana","subtema":"Ángulos complementarios","dificultad":"baja","tipo":"seleccion_multiple","anio":2021,"pregunta":"Dos ángulos son complementarios. Uno mide 35°. ¿Cuánto mide el otro?","alternativas":["35°","45°","55°","65°"],"respuesta_correcta":"55°","explicacion":"Ángulos complementarios suman 90°. 90° − 35° = 55°."},
  {"id":136,"asignatura":"matematica_m1","tema":"Números","eje_tematico":"Números y Operaciones","subtema":"Divisibilidad","dificultad":"baja","tipo":"seleccion_multiple","anio":2023,"pregunta":"¿Cuál de los siguientes números es divisible por 3?","alternativas":["124","217","321","445"],"respuesta_correcta":"321","explicacion":"Un número es divisible por 3 si la suma de sus cifras lo es. 3+2+1 = 6, que es divisible por 3."},
  {"id":137,"asignatura":"matematica_m1","tema":"Álgebra y Funciones","eje_tematico":"Funciones","subtema":"Función par e impar","dificultad":"alta","tipo":"seleccion_multiple","anio":2022,"pregunta":"¿Cuál de las siguientes funciones es una función par?","alternativas":["f(x)=x³","f(x)=x+1","f(x)=x²","f(x)=x²+x"],"respuesta_correcta":"f(x)=x²","explicacion":"Una función es par si f(−x)=f(x). Para f(x)=x²: f(−x)=(−x)²=x²=f(x). ✓"},
  {"id":138,"asignatura":"matematica_m1","tema":"Geometría","eje_tematico":"Geometría Plana","subtema":"Trapecio","dificultad":"media","tipo":"seleccion_multiple","anio":2023,"pregunta":"El área de un trapecio con bases de 6 cm y 10 cm, y altura de 4 cm es:","alternativas":["24 cm²","32 cm²","40 cm²","60 cm²"],"respuesta_correcta":"32 cm²","explicacion":"A = ((b₁+b₂)/2) × h = ((6+10)/2) × 4 = 8 × 4 = 32 cm²."},
  {"id":139,"asignatura":"matematica_m1","tema":"Probabilidades y Estadística","eje_tematico":"Probabilidad","subtema":"Eventos complementarios","dificultad":"media","tipo":"seleccion_multiple","anio":2022,"pregunta":"La probabilidad de que llueva mañana es 0,3. ¿Cuál es la probabilidad de que NO llueva?","alternativas":["0,3","0,5","0,7","0,9"],"respuesta_correcta":"0,7","explicacion":"P(no llueva) = 1 − P(llueva) = 1 − 0,3 = 0,7."},
  {"id":140,"asignatura":"matematica_m1","tema":"Álgebra y Funciones","eje_tematico":"Álgebra","subtema":"Producto notable","dificultad":"media","tipo":"seleccion_multiple","anio":2021,"pregunta":"¿Cuál es el resultado de (x + 3)²?","alternativas":["x²+9","x²+6x+9","x²+3x+9","x²+6x+3"],"respuesta_correcta":"x²+6x+9","explicacion":"(a+b)² = a²+2ab+b² = x²+2(x)(3)+3² = x²+6x+9."},
  {"id":141,"asignatura":"matematica_m1","tema":"Números","eje_tematico":"Números y Operaciones","subtema":"Interés simple","dificultad":"alta","tipo":"seleccion_multiple","anio":2023,"pregunta":"Se depositan $500.000 a una tasa de interés simple del 6% anual durante 2 años. ¿Cuánto se gana de interés?","alternativas":["$30.000","$60.000","$120.000","$600.000"],"respuesta_correcta":"$60.000","explicacion":"I = capital × tasa × tiempo = 500.000 × 0,06 × 2 = $60.000."},
  {"id":142,"asignatura":"matematica_m1","tema":"Geometría","eje_tematico":"Geometría Sólida","subtema":"Área de superficie","dificultad":"alta","tipo":"seleccion_multiple","anio":2022,"pregunta":"¿Cuál es el área lateral de un cilindro de radio 3 cm y altura 8 cm? (π ≈ 3,14)","alternativas":["75,36 cm²","150,72 cm²","226,08 cm²","301,44 cm²"],"respuesta_correcta":"150,72 cm²","explicacion":"A lateral = 2πrh = 2 × 3,14 × 3 × 8 = 150,72 cm²."},
  {"id":143,"asignatura":"matematica_m1","tema":"Probabilidades y Estadística","eje_tematico":"Estadística","subtema":"Frecuencia relativa","dificultad":"media","tipo":"seleccion_multiple","anio":2021,"pregunta":"En una clase de 25 alumnos, 10 aprobaron con nota 7. ¿Cuál es la frecuencia relativa de notas 7?","alternativas":["0,25","0,4","0,5","0,7"],"respuesta_correcta":"0,4","explicacion":"Fr = 10/25 = 0,4 (equivale al 40%)."},
  {"id":144,"asignatura":"matematica_m1","tema":"Álgebra y Funciones","eje_tematico":"Funciones","subtema":"Función inversa","dificultad":"alta","tipo":"seleccion_multiple","anio":2023,"pregunta":"Si f(x) = 3x − 1, ¿cuál es f⁻¹(x)?","alternativas":["(x+1)/3","3x+1","(x−1)/3","1/(3x−1)"],"respuesta_correcta":"(x+1)/3","explicacion":"Se despeja x: y=3x−1 → x=(y+1)/3. Entonces f⁻¹(x)=(x+1)/3."},
  {"id":145,"asignatura":"matematica_m1","tema":"Números","eje_tematico":"Números y Operaciones","subtema":"Operatoria con racionales","dificultad":"media","tipo":"seleccion_multiple","anio":2022,"pregunta":"¿Cuánto es 2/3 ÷ 4/9?","alternativas":["8/27","3/2","2/3","6/4"],"respuesta_correcta":"3/2","explicacion":"Dividir fracciones: multiplicar por el inverso. (2/3) × (9/4) = 18/12 = 3/2."},
  {"id":146,"asignatura":"matematica_m1","tema":"Geometría","eje_tematico":"Geometría Plana","subtema":"Razones trigonométricas","dificultad":"alta","tipo":"seleccion_multiple","anio":2023,"pregunta":"En un triángulo rectángulo, el cateto opuesto mide 3 y la hipotenusa mide 5. ¿Cuánto vale el seno del ángulo?","alternativas":["3/4","3/5","4/5","5/3"],"respuesta_correcta":"3/5","explicacion":"sen(θ) = cateto opuesto / hipotenusa = 3/5."},
  {"id":147,"asignatura":"matematica_m1","tema":"Probabilidades y Estadística","eje_tematico":"Probabilidad","subtema":"Regla de la adición","dificultad":"alta","tipo":"seleccion_multiple","anio":2022,"pregunta":"P(A)=0,4, P(B)=0,3, P(A∩B)=0,1. ¿Cuánto es P(A∪B)?","alternativas":["0,5","0,6","0,7","0,8"],"respuesta_correcta":"0,6","explicacion":"P(A∪B) = P(A)+P(B)−P(A∩B) = 0,4+0,3−0,1 = 0,6."},
