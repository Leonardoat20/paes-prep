  {"id":149,"asignatura":"matematica_m1","tema":"Geometría","eje_tematico":"Geometría Plana","subtema":"Polígonos regulares","dificultad":"media","tipo":"seleccion_multiple","anio":2022,"pregunta":"¿Cuánto es la suma de los ángulos interiores de un hexágono?","alternativas":["360°","540°","720°","900°"],"respuesta_correcta":"720°","explicacion":"Suma de ángulos = (n−2)×180° = (6−2)×180° = 4×180° = 720°."},
